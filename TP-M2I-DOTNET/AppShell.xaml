<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="TP_M2I_DOTNET.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:TP_M2I_DOTNET.Views"
    Shell.FlyoutBehavior="Flyout"
    Title="TP_M2I_DOTNET">
    
    <Shell.Resources>
        <ResourceDictionary>
            <Style x:Key="BaseStyle" TargetType="Element">
                <Setter Property="Shell.BackgroundColor" Value="#455A64" />
                <Setter Property="Shell.ForegroundColor" Value="White" />
                <Setter Property="Shell.TitleColor" Value="White" />
                <Setter Property="Shell.TabBarBackgroundColor" Value="#455A64" />
                <Setter Property="Shell.TabBarForegroundColor" Value="White" />
                <Setter Property="Shell.TabBarUnselectedColor" Value="#95FFFFFF" />
            </Style>
        </ResourceDictionary>
    </Shell.Resources>

    <ShellContent
        Title="Tasks"
        ContentTemplate="{DataTemplate views:TasksPage}"
        Route="tasks" />

    <ShellContent
        Title="Simulation"
        ContentTemplate="{DataTemplate views:SimulationTasksPage}"
        Route="simulation" />

</Shell>
