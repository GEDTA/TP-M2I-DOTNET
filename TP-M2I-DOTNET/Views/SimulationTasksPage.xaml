<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:TP_M2I_DOTNET.ViewModels"
             xmlns:models="clr-namespace:TP_M2I_DOTNET.Models"
             x:Class="TP_M2I_DOTNET.Views.SimulationTasksPage"
             Title="Simulation des tâches">

    <ContentPage.Resources>
        <ResourceDictionary>
            <Style x:Key="TaskCardStyle" TargetType="Frame">
                <Setter Property="Margin" Value="10,5" />
                <Setter Property="Padding" Value="10" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="BackgroundColor" Value="#FFFFFF" />
            </Style>

            <Style x:Key="TaskTitleStyle" TargetType="Label">
                <Setter Property="FontSize" Value="16" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="TextColor" Value="#000000" />
            </Style>

            <Style x:Key="TaskPriorityStyle" TargetType="Label">
                <Setter Property="FontSize" Value="14" />
                <Setter Property="TextColor" Value="#666666" />
            </Style>

            <Style x:Key="TaskStatusStyle" TargetType="Label">
                <Setter Property="FontSize" Value="14" />
                <Setter Property="TextColor" Value="#666666" />
                <Setter Property="VerticalOptions" Value="Center" />
            </Style>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,Auto,*">
        <!-- Bouton pour revenir à l'API réelle -->
        <Button Grid.Row="0"
                Text="Retourner à l'API"
                Command="{Binding NavigateToApiCommand}"
                Margin="10"
                BackgroundColor="#007AFF"
                TextColor="White"
                CornerRadius="8"/>

        <!-- Filtres -->
        <StackLayout Grid.Row="1" 
                     Orientation="Horizontal" 
                     Padding="10" 
                     BackgroundColor="#F5F5F5">
            <Label Text="Filtrer par statut:" 
                   VerticalOptions="Center" 
                   Margin="0,0,10,0" />
            <Picker x:Name="StatusFilter" 
                    SelectedIndexChanged="OnStatusFilterChanged" 
                    WidthRequest="150"
                    BackgroundColor="#E0E0E0"
                    TextColor="Black">
                <Picker.Items>
                    <x:String>Tous</x:String>
                    <x:String>À faire</x:String>
                    <x:String>En cours</x:String>
                    <x:String>Terminé</x:String>
                </Picker.Items>
            </Picker>
        </StackLayout>

        <!-- Liste des tâches -->
        <RefreshView Grid.Row="2" 
                     IsRefreshing="{Binding IsRefreshing}" 
                     Command="{Binding RefreshCommand}">
            <CollectionView ItemsSource="{Binding Tasks}"
                          EmptyView="Aucune tâche trouvée"
                          SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame Style="{StaticResource TaskCardStyle}">
                            <Grid ColumnDefinitions="*,Auto">
                                <StackLayout Grid.Column="0">
                                    <Label Text="{Binding Title}" 
                                           Style="{StaticResource TaskTitleStyle}" />
                                    <Label Text="{Binding Priority, StringFormat='Priorité: {0}'}" 
                                           Style="{StaticResource TaskPriorityStyle}">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" 
                                                        Binding="{Binding Priority}" 
                                                        Value="High">
                                                <Setter Property="TextColor" 
                                                        Value="Red" />
                                            </DataTrigger>
                                            <DataTrigger TargetType="Label" 
                                                        Binding="{Binding Priority}" 
                                                        Value="Medium">
                                                <Setter Property="TextColor" 
                                                        Value="Orange" />
                                            </DataTrigger>
                                            <DataTrigger TargetType="Label" 
                                                        Binding="{Binding Priority}" 
                                                        Value="Low">
                                                <Setter Property="TextColor" 
                                                        Value="Green" />
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>
                                </StackLayout>
                                <Label Grid.Column="1" 
                                       Text="{Binding Status}" 
                                       Style="{StaticResource TaskStatusStyle}">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label" 
                                                    Binding="{Binding Status}" 
                                                    Value="Todo">
                                            <Setter Property="Text" 
                                                    Value="À faire" />
                                            <Setter Property="TextColor" 
                                                    Value="Gray" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="Label" 
                                                    Binding="{Binding Status}" 
                                                    Value="InProgress">
                                            <Setter Property="Text" 
                                                    Value="En cours" />
                                            <Setter Property="TextColor" 
                                                    Value="Blue" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="Label" 
                                                    Binding="{Binding Status}" 
                                                    Value="Done">
                                            <Setter Property="Text" 
                                                    Value="Terminé" />
                                            <Setter Property="TextColor" 
                                                    Value="Green" />
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>
    </Grid>
</ContentPage>
